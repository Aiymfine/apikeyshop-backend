generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model platforms {
  id                Int                 @id @default(autoincrement())
  name              String
  slug              String              @unique
  owner_id          Int
  domain            String?
  description       String?
  is_active         Boolean             @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  customers         customers[]
  plans             plans[]
  api_keys          api_keys[]
  subscriptions     subscriptions[]
  invoices          invoices[]
  webhook_endpoints webhook_endpoints[]

  @@index([owner_id], map: "idx_platforms_owner_id")
}

model api_keys {
  id             Int              @id @default(autoincrement())
  customer_id    Int
  platform_id    Int
  key_prefix     String
  key_hash       String
  name           String?
  status         String           @default("active")
  last_used_at   DateTime?        @db.Timestamptz(6)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  customers      customers        @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  platforms      platforms        @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  usage_counters usage_counters[]
  usage_daily    usage_daily[]
  usage_monthly  usage_monthly[]

  @@index([key_prefix], map: "idx_api_keys_prefix")
  @@index([platform_id], map: "idx_api_keys_platform_id")
}

model customers {
  id                Int                 @id @default(autoincrement())
  email             String              @unique
  name              String
  password_hash     String
  platform_id       Int?
  role              String              @default("customer")
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  api_keys          api_keys[]
  invoices          invoices[]
  platforms         platforms?          @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions     subscriptions[]
  webhook_endpoints webhook_endpoints[]
}

model invoice_items {
  id          Int      @id @default(autoincrement())
  invoice_id  Int
  description String
  quantity    Int      @default(1)
  unit_cents  Int
  total_cents Int
  invoices    invoices @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model invoices {
  id              Int             @id @default(autoincrement())
  customer_id     Int
  platform_id     Int
  subscription_id Int?
  status          String          @default("draft")
  total_cents     Int             @default(0)
  period_start    DateTime?       @db.Timestamptz(6)
  period_end      DateTime?       @db.Timestamptz(6)
  issued_at       DateTime?       @db.Timestamptz(6)
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  invoice_items   invoice_items[]
  customers       customers       @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  platforms       platforms       @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions   subscriptions?  @relation(fields: [subscription_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model plans {
  id            Int             @id @default(autoincrement())
  platform_id   Int
  name          String
  req_per_min   Int
  monthly_quota Int
  price_cents   Int
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  platforms     platforms       @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscriptions subscriptions[]

  @@index([platform_id], map: "idx_plans_platform_id")
}

model subscriptions {
  id                   Int        @id @default(autoincrement())
  customer_id          Int
  platform_id          Int
  plan_id              Int
  status               String     @default("active")
  current_period_start DateTime?  @default(now()) @db.Timestamptz(6)
  current_period_end   DateTime?  @default(dbgenerated("(now() + '30 days'::interval)")) @db.Timestamptz(6)
  created_at           DateTime?  @default(now()) @db.Timestamptz(6)
  invoices             invoices[]
  customers            customers  @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  platforms            platforms  @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  plans                plans      @relation(fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([platform_id], map: "idx_subscriptions_platform_id")
}

model usage_counters {
  id           Int      @id @default(autoincrement())
  api_key_id   Int
  window_start DateTime @db.Timestamptz(6)
  count        Int      @default(0)
  api_keys     api_keys @relation(fields: [api_key_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([api_key_id, window_start])
}

model usage_daily {
  id         Int      @id @default(autoincrement())
  api_key_id Int
  date       DateTime @db.Date
  count      Int      @default(0)
  api_keys   api_keys @relation(fields: [api_key_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([api_key_id, date])
}

model usage_monthly {
  id         Int      @id @default(autoincrement())
  api_key_id Int
  year_month String
  count      Int      @default(0)
  api_keys   api_keys @relation(fields: [api_key_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([api_key_id, year_month])
}

model webhook_attempts {
  id                Int               @id @default(autoincrement())
  endpoint_id       Int
  event_type        String
  payload           Json
  status            String            @default("pending")
  attempt_count     Int               @default(0)
  next_retry_at     DateTime?         @default(now()) @db.Timestamptz(6)
  last_response     String?
  last_attempted_at DateTime?         @db.Timestamptz(6)
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  webhook_endpoints webhook_endpoints @relation(fields: [endpoint_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status, next_retry_at], map: "idx_webhook_attempts_retry")
}

model webhook_endpoints {
  id               Int                @id @default(autoincrement())
  customer_id      Int
  platform_id      Int
  url              String
  secret           String
  events           String[]           @default([])
  is_active        Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  webhook_attempts webhook_attempts[]
  customers        customers          @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  platforms        platforms          @relation(fields: [platform_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([platform_id], map: "idx_webhook_endpoints_platform_id")
}
